# Scholar India Mail Server — Environment Variables
# Add these as Environment Variables in your Vercel project settings

# Gmail address used to send emails
MAIL_USER=scholarindiapub@gmail.com

# Gmail App Password (NOT your login password)
# Generate at: https://myaccount.google.com/apppasswords
MAIL_PASS=your_16_char_app_password_here

# Secret API key — all requests from your frontend must include this
# Generate a random key at: https://generate-secret.vercel.app/32
# Add the SAME key to your main frontend's .env as VITE_MAIL_API_KEY
MAIL_API_KEY=your_random_secret_key_here

# Port (Vercel ignores this)
PORT=4001
